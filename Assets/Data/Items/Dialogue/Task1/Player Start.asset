        m_PersistentCalls:
          m_Calls: []
  - ID: 02
    image: {fileID: 0}
    content: "\u9996\u5148\u4F60\u5F97\u5411\u6211\u4EEC\u8FD9\u8BC1\u660E\u4F60\u7684\u5B9E\u529B\uFF0C\u5148\u6311\u51E0\u4EF6\u8D81\u624B\u7684\u6B66\u5668\u5427"
    task: {fileID: 0}
    options:
    - text: "\u628A\u4F60\u6709\u7684\u90FD\u62FF\u51FA\u6765"
      targetID: 03
      takeQuest: 1
      onSelectAction:
        m_PersistentCalls:
          m_Calls: []
    - text: "\u6211\u4E0D\u9700\u8981"
