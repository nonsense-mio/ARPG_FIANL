  dialoguePieces:
  - ID: 01
    image: {fileID: 0}
    content: "\u4F60\u597D\uFF0C\u5192\u9669\u8005\uFF01\u8BF7\u5BB9\u8BB8\u6211\u4ECB\u7ECD\u4E0B\u81EA\u5DF1\uFF0C\u6211\u662F\u5E0C\u745E\uFF0C\u90A3\u8FB9\u7684\u90A3\u4E2A\u5BB6\u4F19\u662F\u6770\u82E5\u7279\uFF0C\u81EA\u4ECE\u8FD9\u4E2A\u738B\u56FD\u9668\u843D\u540E\uFF0C\u6211\u4EEC\u5C31\u5949\u547D\u575A\u5B88\u5728\u8FD9\u91CC...\u4F60\u5E94\u8BE5\u4E5F\u662F\u88AB\u6D3E\u8FC7\u6765\u7684\u628A"
    task: {fileID: 0}
    options:
